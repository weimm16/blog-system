# ================================================
# VexGo Environment Variables Example
# ================================================
# How to use:
# 1. Copy this file to .env
# 2. Edit the values according to your environment
# Configuration priority: command-line > config file > environment variables > defaults

# ==================== JWT Secret (REQUIRED for production) ====================
# Must be a long random string. Generate with: openssl rand -base64 32
JWT_SECRET=your-very-long-random-secret-here-change-this-in-production

# ==================== Server Configuration ====================
# Server listen address
ADDR=0.0.0.0

# Server listen port
PORT=3001

# Data directory (stores SQLite database and uploaded media files)
DATA=./data

# ==================== Database Configuration ====================
# Database type (default: sqlite, options: sqlite, mysql, postgres)
DB_TYPE=sqlite

# ==================== MySQL / PostgreSQL settings (only required when not using sqlite) ====================
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=vexgo_user
# DB_PASSWORD=your-db-password
# DB_NAME=vexgo_db

# PostgreSQL only - SSL mode
# DB_SSL_MODE=disable

# ==================== SSO / Single Sign-On ====================
# Public base URL of your instance (REQUIRED when using reverse proxy or Docker)
# Used to generate correct OAuth2 callback URLs
BASE_URL=https://vexgo.example.com

# Allow local password login (set to false to enforce SSO-only)
ALLOW_LOCAL_LOGIN=true

# ==================== GitHub SSO ====================
# Register OAuth App at https://github.com/settings/developers
# Callback URL: https://your-domain/api/sso/github/callback
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ==================== Google SSO ====================
# Create credentials at https://console.developers.google.com
# Callback URL: https://your-domain/api/sso/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ==================== OIDC SSO (Keycloak, Authentik, Authelia, Okta, Casdoor, etc.) ====================
# Enable OIDC login
OIDC_ENABLED=false

# Issuer URL (required)
# Example: https://auth.example.com/realms/myrealm
OIDC_ISSUER_URL=

# OIDC Client credentials
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# ==================== OIDC Advanced Options (optional) ====================
# Space-separated scopes
OIDC_SCOPES=openid profile email

# Claim names
OIDC_EMAIL_CLAIM=email
OIDC_NAME_CLAIM=name
OIDC_GROUP_CLAIM=groups

# Comma-separated list of allowed groups (empty = allow all)
OIDC_ALLOWED_GROUPS=

# Auto-redirect to OIDC provider on login page
OIDC_AUTO_REDIRECT=false

# Require email_verified=true in token
OIDC_VERIFY_EMAIL=false

# Manual endpoint overrides (only needed if discovery fails)
# OIDC_AUTH_URL=
# OIDC_TOKEN_URL=
# OIDC_USERINFO_URL=
